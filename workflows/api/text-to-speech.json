{
  "prompt": {
    "1": {
      "class_type": "LlamaCppLLMProviderNode",
      "inputs": { "model_name": "your-llm.gguf", "n_ctx": 2048, "n_gpu_layers": 0, "system_prompt": "" }
    },
    "2": {
      "class_type": "PocketTTSProviderNode",
      "inputs": {
        "language": "english",
        "default_voice_path": "sample_voice.safetensors",
        "default_voice_id": "sample"
      }
    },
    "3": {
      "class_type": "RealtimePipelineNode",
      "inputs": {
        "pipeline_name": "text-to-speech",
        "llm": ["1", 0],
        "tts": ["2", 0],
        "voice": "your-voice",
        "instructions": "You are a helpful assistant.",
        "temperature": 0.7
      }
    }
  },
  "client_id": "example-text-to-speech"
}
