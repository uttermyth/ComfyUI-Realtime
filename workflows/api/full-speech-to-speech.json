{
  "prompt": {
    "1": {
      "class_type": "LlamaCppLLMProviderNode",
      "inputs": { "model_name": "your-llm.gguf", "n_ctx": 2048, "n_gpu_layers": 0, "system_prompt": "" }
    },
    "2": {
      "class_type": "PocketTTSProviderNode",
      "inputs": {
        "language": "english",
        "default_voice_path": "sample_voice.safetensors",
        "default_voice_id": "sample"
      }
    },
    "3": { "class_type": "SileroVADProviderNode", "inputs": { "threshold": 0.5 } },
    "4": { "class_type": "WhisperCppSTTProviderNode", "inputs": { "model_name": "your-whisper-model.bin" } },
    "5": {
      "class_type": "RealtimePipelineNode",
      "inputs": {
        "pipeline_name": "full-speech-to-speech",
        "llm": ["1", 0],
        "tts": ["2", 0],
        "vad": ["3", 0],
        "stt": ["4", 0],
        "voice": "your-voice",
        "instructions": "You are a helpful voice assistant. Keep replies brief.",
        "temperature": 0.7
      }
    }
  },
  "client_id": "example-full-speech-to-speech"
}
